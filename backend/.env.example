# ============================================================
# Election Copilot AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# Server
PORT=5000

# Google Gemini API Key (required for AI-powered responses)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini Model (optional — defaults to gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Frontend URL for CORS (optional — defaults to http://localhost:5174)
FRONTEND_URL=http://localhost:5174
